{% comment %}
  Agalaz Virtual Try-On — Shopify Theme Extension
  Opens an iframe modal with the full try-on experience powered by Gemini AI.
  Requires: API key configured in block settings.
{% endcomment %}

<div id="agalaz-tryon-widget" class="agalaz-widget">
  <button id="agalaz-tryon-btn" type="button"
    style="
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      border: none;
      border-radius: 10px;
      background: {{ block.settings.button_color }};
      color: {{ block.settings.button_text_color }};
      cursor: pointer;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 0.05em;
      transition: opacity 0.2s, transform 0.1s;
    ">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
      <path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>
    </svg>
    {{ block.settings.button_text }}
  </button>
</div>

<!-- Modal overlay -->
<div id="agalaz-modal-overlay" style="
  display: none;
  position: fixed;
  inset: 0;
  z-index: 999999;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  align-items: center;
  justify-content: center;
">
  <div style="
    background: white;
    border-radius: 16px;
    overflow: hidden;
    width: 90vw;
    max-width: 420px;
    height: 85vh;
    max-height: 750px;
    box-shadow: 0 25px 50px rgba(0,0,0,0.25);
    animation: agalazSlideUp 0.3s ease;
  ">
    <iframe id="agalaz-iframe" style="width: 100%; height: 100%; border: none;" allow="camera"></iframe>
  </div>
</div>

<style>
  #agalaz-tryon-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  #agalaz-tryon-btn:active {
    transform: translateY(0);
  }
  @keyframes agalazSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
(function() {
  var API_KEY = {{ block.settings.api_key | json }};
  var APP_URL = {{ block.settings.app_url | json }};
  var garmentImage = '{{ product.featured_image | image_url: width: 512 }}';
  var productId = '{{ product.id }}';
  var variantId = '{{ product.selected_or_first_available_variant.id }}';
  var lang = document.documentElement.lang === 'es' ? 'es' : 'en';

  if (!API_KEY || API_KEY === '') {
    console.warn('[Agalaz] No API key configured. Go to theme editor → Agalaz block → enter your API key.');
    return;
  }

  if (!APP_URL || APP_URL === '') {
    APP_URL = 'https://shopify-agalaz.vercel.app';
  }

  var btn = document.getElementById('agalaz-tryon-btn');
  var overlay = document.getElementById('agalaz-modal-overlay');
  var iframe = document.getElementById('agalaz-iframe');

  function openModal() {
    var params = 'key=' + encodeURIComponent(API_KEY) + '&lang=' + lang;
    if (garmentImage) params += '&garment=' + encodeURIComponent(garmentImage);
    iframe.src = APP_URL + '/embed?' + params;
    overlay.style.display = 'flex';
  }

  function closeModal() {
    overlay.style.display = 'none';
    iframe.src = '';
  }

  btn.addEventListener('click', openModal);
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });

  // Listen for messages from the iframe
  window.addEventListener('message', function(e) {
    if (!e.data || !e.data.type) return;
    if (e.data.type === 'agalaz:close') closeModal();
    if (e.data.type === 'agalaz:addToCart') {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 }),
      }).then(function() {
        window.location.href = '/cart';
      });
    }
  });
})();
</script>

{% schema %}
{
  "name": "Agalaz Virtual Try-On",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_key",
      "label": "API Key",
      "info": "Your Agalaz API key (starts with agz_live_). Get it from the app dashboard."
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "default": "https://shopify-agalaz.vercel.app",
      "info": "The URL of your Agalaz app deployment."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Try it on with AI"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#1e1b4b"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
